rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Modo de Manutenção: Regras restritas enquanto o banco é reestabelecido
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Bloqueia escritas externas temporariamente para evitar erros de permissão persistentes no console
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
